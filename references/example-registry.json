    {
      "id": "nextjs_ci",
      "stack": "nextjs",
      "kind": "infra",
      "source": "/templates/infra/ci",
      "requires": ["nextjs_base"],
      "conflicts_with": [],
      "owns": [".github/workflows/**"],
      "placeholder_map": {},
      "post_steps": [],
      "verify": []
    }
