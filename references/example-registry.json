{
  "stack_defaults": {
    "kmp": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    },
    "nextjs": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    }
  },
  "packs": [
    {
      "id": "kmp_base",
      "stack": "kmp",
      "kind": "base",
      "source": "/templates/kmp/base",
      "requires": [],
      "conflicts_with": [],
      "owns": ["**/*"],
      "placeholder_map": {
        "project_name": "MyApp",
        "package_name": "com.example.myapp"
      },
      "post_steps": [
        "./gradlew :shared:build",
        "./gradlew :composeApp:build"
      ],
      "verify": [
        "./gradlew :shared:build",
        "./gradlew :composeApp:build"
      ]
    },
    {
      "id": "kmp_auth",
      "stack": "kmp",
      "kind": "feature",
      "source": "/templates/kmp/auth",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": ["shared/**", "composeApp/**"],
      "placeholder_map": {
        "auth_provider": "clerk"
      },
      "post_steps": [],
      "verify": ["./gradlew :shared:build"]
    },
    {
      "id": "kmp_ui_theme",
      "stack": "kmp",
      "kind": "feature",
      "source": "/templates/kmp/ui-theme",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": ["composeApp/**"],
      "placeholder_map": {
        "theme_preset": "neutral"
      },
      "post_steps": [],
      "verify": ["./gradlew :composeApp:build"]
    },
    {
      "id": "kmp_room",
      "stack": "kmp",
      "kind": "feature",
      "source": "/templates/kmp/room",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": ["shared/**"],
      "placeholder_map": {},
      "post_steps": [],
      "verify": ["./gradlew :shared:build"]
    },
    {
      "id": "kmp_github",
      "stack": "kmp",
      "kind": "infra",
      "source": "/templates/infra/github",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": [".github/**"],
      "placeholder_map": {},
      "post_steps": [],
      "verify": []
    },
    {
      "id": "kmp_ci",
      "stack": "kmp",
      "kind": "infra",
      "source": "/templates/infra/ci",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": [".github/workflows/**"],
      "placeholder_map": {},
      "post_steps": [],
      "verify": []
    },
    {
      "id": "nextjs_base",
      "stack": "nextjs",
      "kind": "base",
      "source": "/templates/nextjs/base",
      "requires": [],
      "conflicts_with": [],
      "owns": ["**/*"],
      "placeholder_map": {
        "project_name": "MyApp"
      },
      "post_steps": ["pnpm build"],
      "verify": ["pnpm build"]
    },
    {
      "id": "nextjs_auth",
      "stack": "nextjs",
      "kind": "feature",
      "source": "/templates/nextjs/auth",
      "requires": ["nextjs_base"],
      "conflicts_with": [],
      "owns": ["src/modules/auth/**"],
      "placeholder_map": {
        "auth_provider": "clerk"
      },
      "post_steps": [],
      "verify": ["pnpm build"]
    },
    {
      "id": "nextjs_ui_theme",
      "stack": "nextjs",
      "kind": "feature",
      "source": "/templates/nextjs/ui-theme",
      "requires": ["nextjs_base"],
      "conflicts_with": [],
      "owns": ["src/modules/ui/**"],
      "placeholder_map": {
        "theme_preset": "neutral"
      },
      "post_steps": [],
      "verify": ["pnpm test"]
    },
    {
      "id": "nextjs_github",
      "stack": "nextjs",
      "kind": "infra",
      "source": "/templates/infra/github",
      "requires": ["nextjs_base"],
