{
  "stack_defaults": {
    "kmp": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    },
    "nextjs": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    }
  },
  "packs": [
    {
      "id": "kmp_base",
      "stack": "kmp",
      "kind": "base",
      "source": "templates/kmp/base",
      "requires": [],
      "conflicts_with": [],
      "owns": ["**/*"],
      "placeholder_map": {
        "project_name": "MyApp",
        "package_name": "com.example.myapp",
        "kmp_auth_include": "",
        "kmp_room_include": "",
        "kmp_ui_theme_include": ""
      },
      "post_steps": [],
      "verify": [
        "./gradlew --no-daemon build"
      ]
    },
    {
      "id": "kmp_ui_theme",
      "stack": "kmp",
      "kind": "feature",
      "source": "templates/kmp/ui_theme",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": ["kmp/ui_theme/**"],
      "placeholder_map": {
        "kmp_ui_theme_include": "include(\":kmp:ui_theme\")\n"
      },
      "post_steps": [],
      "verify": [
        "./gradlew --no-daemon :kmp:ui_theme:build"
      ]
    },
    {
      "id": "kmp_auth",
      "stack": "kmp",
      "kind": "feature",
      "source": "templates/kmp/auth",
      "requires": ["kmp_base", "kmp_ui_theme"],
      "conflicts_with": [],
      "owns": ["kmp/auth/**"],
      "placeholder_map": {
        "kmp_auth_include": "include(\":kmp:auth\")\n"
      },
      "post_steps": [],
      "verify": [
        "./gradlew --no-daemon :kmp:auth:build"
      ]
    },
    {
      "id": "kmp_room",
      "stack": "kmp",
      "kind": "feature",
      "source": "templates/kmp/room_data",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": ["kmp/room_data/**"],
      "placeholder_map": {
        "kmp_room_include": "include(\":kmp:room_data\")\n"
      },
      "post_steps": [],
      "verify": [
        "./gradlew --no-daemon :kmp:room_data:build"
      ]
    },
    {
      "id": "kmp_ci",
      "stack": "kmp",
      "kind": "infra",
      "source": "templates/kmp/ci",
      "requires": ["kmp_base"],
      "conflicts_with": [],
      "owns": [".github/workflows/**"],
      "placeholder_map": {},
      "post_steps": [],
      "verify": [
        "./gradlew --no-daemon build"
      ]
    },
    {
      "id": "nextjs_base",
      "stack": "nextjs",
      "kind": "base",
      "source": "$NEXTJS_TEMPLATE_ROOT",
      "requires": [],
      "conflicts_with": [],
      "owns": ["**/*"],
      "placeholder_map": {
        "project_name": "MyApp"
      },
      "post_steps": [],
      "verify": [
        "pnpm install --frozen-lockfile",
        "pnpm test",
        "pnpm build"
      ]
    },
    {
      "id": "nextjs_auth",
      "stack": "nextjs",
      "kind": "feature",
      "source": "$NEXTJS_TEMPLATE_ROOT",
      "requires": ["nextjs_base"],
      "conflicts_with": [],
      "owns": ["src/modules/auth/**"],
      "placeholder_map": {
        "auth_provider": "clerk"
      },
      "post_steps": [],
      "verify": [
        "pnpm install --frozen-lockfile",
        "pnpm test",
        "pnpm build"
      ]
    },
    {
      "id": "nextjs_ui_theme",
      "stack": "nextjs",
      "kind": "feature",
      "source": "$NEXTJS_TEMPLATE_ROOT",
      "requires": ["nextjs_base"],
      "conflicts_with": [],
      "owns": ["src/modules/ui/**"],
      "placeholder_map": {
        "theme_preset": "neutral"
      },
      "post_steps": [],
      "verify": [
        "pnpm install --frozen-lockfile",
        "pnpm test",
        "pnpm build"
      ]
    }
  ]
}
