{
  "version": "0.4.3",
  "min_scaffold_py_version": "0.1.0",
  "_note": "v0.4.3: nextjs base bumped to v0.1.7 (round-out-the-core audit wave: proxy rewired through @/modules/auth; AuthProviderName single-sourced from @/config; zod env validation; route boundaries global-error.tsx + not-found.tsx. IMPORTANT — loading.tsx intentionally lives INSIDE (auth)/ not at root: a root-level loading.tsx wraps every route in a Suspense boundary, and Server Components that throw NEXT_REDIRECT inside Suspense stream a 200 + RSC redirect payload instead of emitting 307, breaking non-JS clients like curl/crawlers). Tags are immutable — safe to cache indefinitely.",
  "stack_defaults": {
    "kmp": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    },
    "nextjs": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    }
  },
  "packs": [
    {
      "id": "kmp_base",
      "stack": "kmp",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/kmp-starter-project@v0.1.2",
      "verify": [
        ["./gradlew", "--no-daemon", "build"]
      ]
    },
    {
      "id": "kmp_auth",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ui_theme",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_room",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ci",
      "stack": "kmp",
      "kind": "infra"
    },
    {
      "id": "nextjs_base",
      "stack": "nextjs",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/base-next-starter@v0.1.7",
      "verify": [
        [
          "pnpm",
          "install",
          "--frozen-lockfile"
        ],
        [
          "pnpm",
          "build"
        ]
      ]
    },
    {
      "id": "nextjs_auth",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ui_theme",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ci",
      "stack": "nextjs",
      "kind": "infra"
    }
  ]
}
