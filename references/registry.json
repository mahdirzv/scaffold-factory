{
  "version": "0.4.5",
  "min_scaffold_py_version": "0.1.0",
  "_note": "v0.4.5: nextjs base bumped to v0.1.9 (Clerk catch-all routes for sign-in/sign-up — Clerk's hosted components probe sub-routes at runtime, so sign-in/[[...rest]]/page.tsx and sign-up/[[...rest]]/page.tsx are required to avoid 'not a catch-all route' errors under live Clerk dev keys). Includes v0.1.8 structural refactor (src/features, src/components/ui, src/lib/design). Tags are immutable — safe to cache indefinitely.",
  "stack_defaults": {
    "kmp": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    },
    "nextjs": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    }
  },
  "packs": [
    {
      "id": "kmp_base",
      "stack": "kmp",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/kmp-starter-project@v0.1.2",
      "verify": [
        ["./gradlew", "--no-daemon", "build"]
      ]
    },
    {
      "id": "kmp_auth",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ui_theme",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_room",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ci",
      "stack": "kmp",
      "kind": "infra"
    },
    {
      "id": "nextjs_base",
      "stack": "nextjs",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/base-next-starter@v0.1.9",
      "verify": [
        [
          "pnpm",
          "install",
          "--frozen-lockfile"
        ],
        [
          "pnpm",
          "build"
        ]
      ]
    },
    {
      "id": "nextjs_auth",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ui_theme",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ci",
      "stack": "nextjs",
      "kind": "infra"
    }
  ]
}
